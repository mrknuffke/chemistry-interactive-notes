  "glossary": [
    {
      "term": "nucleus",
      "definition": "The tiny, dense central core of an atom containing positive protons and neutral neutrons.",
      "lessonId": "1-1a",
      "sectionId": "s-parts"
    },
    {
      "term": "atomic number",
      "definition": "The number of protons in an atom's nucleus, which uniquely identifies the chemical element.",
      "lessonId": "1-1a",
      "sectionId": "s-parts"
    },
    {
      "term": "shells",
      "definition": "Concentric energy levels surrounding the nucleus where electrons are grouped.",
      "lessonId": "1-1a",
      "sectionId": "s-parts"
    },
    {
      "term": "valence electrons",
      "definition": "The electrons in the outermost occupied shell of an atom that participate in chemical bonding.",
      "lessonId": "1-1a",
      "sectionId": "s-parts"
    },
    {
      "term": "isotopes",
      "definition": "Atoms of the same element that have the same number of protons but different numbers of neutrons, resulting in different atomic masses.",
      "lessonId": "1-1a",
      "sectionId": "s-parts"
    },
    {
      "term": "Atomic radius",
      "definition": "The distance from the center of the nucleus to the outer boundary of its electron cloud.",
      "lessonId": "1-1b",
      "sectionId": "s-reactivity"
    },
    {
      "term": "ionization energy",
      "definition": "The energy required to completely remove a valence electron from a gaseous atom.",
      "lessonId": "1-1b",
      "sectionId": "s-reactivity"
    },
    {
      "term": "electronegativity",
      "definition": "A measure of an atom's relative ability to attract shared electrons in a chemical bond.",
      "lessonId": "1-1b",
      "sectionId": "s-reactivity"
    },
    {
      "term": "electrostatic force",
      "definition": "The attractive or repulsive force between electrical charges (protons and electrons).",
      "lessonId": "1-2a",
      "sectionId": "s-forces"
    },
    {
      "term": "electronegativity difference",
      "definition": "The difference in electronegativity values between two bonded atoms, deciding the bond's electronic character.",
      "lessonId": "1-2a",
      "sectionId": "s-tug"
    },
    {
      "term": "nonpolar covalent bond",
      "definition": "A covalent bond in which valence electrons are shared equally between atoms (typically ΔEN < 0.5).",
      "lessonId": "1-2a",
      "sectionId": "s-tug"
    },
    {
      "term": "polar covalent bond",
      "definition": "A covalent bond in which valence electrons are shared unequally, creating partial positive and negative charges (0.5 ≤ ΔEN < 1.7).",
      "lessonId": "1-2a",
      "sectionId": "s-tug"
    },
    {
      "term": "ionic bond",
      "definition": "A chemical bond resulting from the electrostatic attraction between oppositely charged ions formed by electron transfer (typically ΔEN ≥ 1.7).",
      "lessonId": "1-2a",
      "sectionId": "s-tug"
    },
    {
      "term": "metallic bond",
      "definition": "The electrostatic attraction between positive metal cations and a delocalized sea of shared valence electrons.",
      "lessonId": "1-2a",
      "sectionId": "s-tug"
    },
    {
      "term": "sea of electrons",
      "definition": "The collective pool of delocalized valence electrons that flow freely around metal cations in a metallic lattice.",
      "lessonId": "1-2a",
      "sectionId": "s-tug"
    },
    {
      "term": "octet rule",
      "definition": "The tendency of main-group atoms to gain, lose, or share electrons in order to acquire a full set of 8 valence electrons.",
      "lessonId": "1-3a",
      "sectionId": "s-sharing"
    },
    {
      "term": "duet rule",
      "definition": "The tendency of hydrogen (and helium) to share or gain electrons to fill its first and only shell with exactly 2 electrons.",
      "lessonId": "1-3a",
      "sectionId": "s-sharing"
    },
    {
      "term": "Lewis structure",
      "definition": "A 2D structural diagram showing how valence electrons are shared as bonds or held as lone pairs around symbols of atoms.",
      "lessonId": "1-3a",
      "sectionId": "s-sharing"
    },
    {
      "term": "single bond",
      "definition": "A covalent bond in which two atoms share one pair of valence electrons (2 electrons).",
      "lessonId": "1-3a",
      "sectionId": "s-guide"
    },
    {
      "term": "lone pairs",
      "definition": "Pairs of valence electrons that are not shared in chemical bonds but reside locally on a single atom.",
      "lessonId": "1-3a",
      "sectionId": "s-guide"
    },
    {
      "term": "double bond",
      "definition": "A covalent bond in which two atoms share two pairs of valence electrons (4 electrons).",
      "lessonId": "1-3a",
      "sectionId": "s-guide"
    },
    {
      "term": "triple bond",
      "definition": "A covalent bond in which two atoms share three pairs of valence electrons (6 electrons).",
      "lessonId": "1-3a",
      "sectionId": "s-guide"
    },
    {
      "term": "intramolecular bonds",
      "definition": "Strong chemical bonds (such as covalent or ionic bonds) that hold atoms together within a molecule.",
      "lessonId": "1-3b",
      "sectionId": "s-attraction"
    },
    {
      "term": "intermolecular forces",
      "definition": "Relatively weak electrical attractions that exist between neighboring chemical particles (molecules).",
      "lessonId": "1-3b",
      "sectionId": "s-attraction"
    },
    {
      "term": "London dispersion force",
      "definition": "The weakest intermolecular force, caused by temporary, induced dipole shifts in electron clouds; present in all molecules.",
      "lessonId": "1-3b",
      "sectionId": "s-types"
    },
    {
      "term": "dipole-dipole force",
      "definition": "An intermolecular force of attraction between the positive and negative ends of adjacent polar molecules.",
      "lessonId": "1-3b",
      "sectionId": "s-types"
    },
    {
      "term": "hydrogen bonding",
      "definition": "An exceptionally strong dipole-dipole attraction that occurs when hydrogen is bonded directly to highly electronegative nitrogen, oxygen, or fluorine atoms.",
      "lessonId": "1-3b",
      "sectionId": "s-types"
    },
    {
      "term": "surface tension",
      "definition": "The inward electrostatic pull experienced by molecules at the surface of a liquid, causing the liquid to minimize its surface area.",
      "lessonId": "1-3b",
      "sectionId": "s-bulk"
    },
    {
      "term": "saturated fat",
      "definition": "A lipid containing fatty acid chains with only single carbon-carbon bonds, resulting in straight, linear shapes that pack tightly and melt at higher temperatures.",
      "lessonId": "C-SPA",
      "sectionId": "s-structure"
    },
    {
      "term": "unsaturated fat",
      "definition": "A lipid containing one or more double carbon-carbon bonds, creating rigid bends or kinks that prevent tight packing and lower the melting point.",
      "lessonId": "C-SPA",
      "sectionId": "s-structure"
    },
    {
      "term": "physical change",
      "definition": "A transformation that changes the state or spacing of particles without breaking covalent bonds or changing chemical identity.",
      "lessonId": "2-2a",
      "sectionId": "s-concept"
    },
    {
      "term": "chemical change",
      "definition": "A process where chemical bonds break and new ones form, rearranging atoms to produce new substances with different properties.",
      "lessonId": "2-2a",
      "sectionId": "s-concept"
    },
    {
      "term": "reactants",
      "definition": "The starting chemical substances consumed in a chemical reaction.",
      "lessonId": "2-2a",
      "sectionId": "s-concept"
    },
    {
      "term": "products",
      "definition": "The newly formed chemical substances produced by a chemical reaction.",
      "lessonId": "2-2a",
      "sectionId": "s-concept"
    },
    {
      "term": "coefficients",
      "definition": "Numbers placed in front of chemical formulas in a balanced equation to represent the relative mole proportions of reactants and products.",
      "lessonId": "C-RXN",
      "sectionId": "s-law"
    },
    {
      "term": "mole",
      "definition": "The standard chemical counting unit representing exactly 6.022 × 10²³ particles (atoms, molecules, or ions).",
      "lessonId": "2-7a",
      "sectionId": "s-dozen"
    },
    {
      "term": "Avogadro's number",
      "definition": "The constant 6.022 × 10²³, representing the number of counting particles in exactly one mole of a substance.",
      "lessonId": "2-7a",
      "sectionId": "s-dozen"
    },
    {
      "term": "molar mass",
      "definition": "The mass in grams of exactly one mole of a chemical substance, measured in grams per mole (g/mol).",
      "lessonId": "2-7a",
      "sectionId": "s-molarmass"
    },
    {
      "term": "grams per mole",
      "definition": "The standard unit (g/mol) used to express the molar mass of an element or compound.",
      "lessonId": "2-7a",
      "sectionId": "s-molarmass"
    },
    {
      "term": "dimensional analysis",
      "definition": "A problem-solving method that uses conversion factors and unit cancellations to convert one unit of measurement to another.",
      "lessonId": "2-7b",
      "sectionId": "s-da"
    },
    {
      "term": "mole ratio",
      "definition": "The ratio of moles of any two substances involved in a balanced chemical equation, representing their scaling proportions.",
      "lessonId": "2-7c",
      "sectionId": "s-recipe"
    },
    {
      "term": "BCA table",
      "definition": "A Before-Change-After stoichiometric grid used to track mole amounts of reactants and products before, during, and after a reaction.",
      "lessonId": "2-7c",
      "sectionId": "s-bca"
    },
    {
      "term": "limiting reactant",
      "definition": "The reactant that is completely consumed first in a reaction, determining the maximum yield of products.",
      "lessonId": "2-7c",
      "sectionId": "s-limiting"
    },
    {
      "term": "excess reactant",
      "definition": "The reactant that remains left over after a chemical reaction halts because the limiting reactant is exhausted.",
      "lessonId": "2-7c",
      "sectionId": "s-limiting"
    }
  ],
